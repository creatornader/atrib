{
  "name": "@atrib/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "atrib": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist"
  ],
  "description": "CLI for atrib. Generate Ed25519 keypairs, manage them in macOS Keychain, publish identity claims to the atrib directory.",
  "author": "atrib <hello@atrib.dev>",
  "license": "Apache-2.0",
  "homepage": "https://atrib.dev",
  "keywords": [
    "atrib",
    "cli",
    "ed25519",
    "keygen"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@atrib/directory": "workspace:*",
    "@atrib/mcp": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
