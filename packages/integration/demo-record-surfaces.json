{
  "schema": "atrib.integration.demo-record-surfaces.v1",
  "record_classes": {
    "offline-local": "Signs or verifies local records only. No public atrib record is created by the surface.",
    "public-proof": "Creates narrow public atrib records for an inspectable proof run.",
    "live-capture": "Captures upstream protocol events and writes verifier replay artifacts. Public atrib records require a separate explicit proof step."
  },
  "endpoint_postures": {
    "local-only": "Uses local files, in-process services, localhost, or mocked endpoints.",
    "public-read": "May read public atrib endpoints but does not write public records.",
    "public-write": "Writes to public atrib services by design.",
    "upstream-capture": "Talks to an upstream non-atrib system to capture protocol artifacts."
  },
  "surfaces": [
