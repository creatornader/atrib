{
  "name": "@atrib/cloudflare-live-proof",
  "version": "0.0.21",
  "private": true,
  "type": "module",
  "description": "Live Cloudflare Agents proof for atrib-signed MCP tool calls.",
  "scripts": {
    "build": "pnpm --filter @atrib/mcp build && tsc --noEmit",
    "deploy": "pnpm --filter @atrib/mcp build && wrangler deploy --secrets-file .tmp/secrets.json",
    "proof": "pnpm --filter @atrib/mcp build && tsx scripts/run-live-proof.ts",
    "test": "pnpm --filter @atrib/cloudflare-live-proof build && vitest run"
  },
  "dependencies": {
    "@atrib/mcp": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "agents": "^0.17.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260723.1",
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.114.0"
  }
}
