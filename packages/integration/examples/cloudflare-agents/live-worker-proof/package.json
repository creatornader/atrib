{
  "name": "@atrib/cloudflare-live-proof",
  "version": "0.0.2",
  "private": true,
  "type": "module",
  "description": "Live Cloudflare Agents proof for atrib-signed MCP tool calls.",
  "scripts": {
    "build": "pnpm --filter @atrib/mcp build && tsc --noEmit",
    "deploy": "pnpm --filter @atrib/mcp build && wrangler deploy --secrets-file .tmp/secrets.json",
    "proof": "pnpm --filter @atrib/mcp build && tsx scripts/run-live-proof.ts"
  },
  "dependencies": {
    "@atrib/mcp": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "agents": "^0.13.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260527.1",
    "@types/node": "^25.9.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "wrangler": "^4.95.0"
  }
}
