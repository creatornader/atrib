{
  "name": "@atrib/cloudflare-oauth-evidence-infra",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Cloudflare Worker and Durable Object reference for atrib OAuth evidence infrastructure.",
  "scripts": {
    "build": "pnpm --filter @atrib/verify... build && tsc --noEmit",
    "dev": "wrangler dev --config wrangler.jsonc",
    "deploy": "wrangler deploy --config wrangler.jsonc",
    "test": "pnpm --filter @atrib/verify... build && vitest run",
    "typecheck": "pnpm --filter @atrib/verify... build && tsc --noEmit"
  },
  "devDependencies": {
    "@atrib/verify": "workspace:*",
    "@cloudflare/vitest-pool-workers": "^0.16.15",
    "@cloudflare/workers-types": "^5.20260714.1",
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.8",
    "wrangler": "^4.100.0"
  }
}
