{
  "name": "@atrib/verify",
  "version": "0.8.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "description": "Verifier library for atrib's verifiable action layer. Checks records, evidence, handoffs, graph derivation, and settlement documents.",
  "author": "atrib <hello@atrib.dev>",
  "license": "Apache-2.0",
  "homepage": "https://atrib.dev",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "attribution",
    "verification",
    "settlement",
    "merchant",
    "ed25519"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@atrib/mcp": "workspace:*",
    "@noble/ed25519": "^3.1.0",
    "@noble/hashes": "^2.2.0",
    "@sd-jwt/core": "0.19.0",
    "@sd-jwt/sd-jwt-vc": "0.19.0",
    "canonicalize": "^3.0.0",
    "jose": "6.2.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "fast-check": "^4.8.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/creatornader/atrib.git",
    "directory": "packages/verify"
  }
