{
  "name": "@atrib/verify",
  "version": "0.1.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "description": "Verifier library for atrib. Per-record verification, graph-derivation re-derivation, and §4.6 settlement-recommendation re-calculation against the atrib spec.",
