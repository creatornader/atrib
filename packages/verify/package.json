    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@atrib/mcp": "workspace:*",
    "@noble/ed25519": "^2.3.0",
    "@noble/hashes": "^2.2.0",
    "canonicalize": "^2.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "fast-check": "^4.7.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
