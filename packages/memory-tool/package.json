{
  "name": "@atrib/memory-tool",
  "version": "0.2.12",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "description": "Memory Tool wrapper for Atrib's verifiable action layer. Signs memory commands while leaving storage under the host's control.",
  "author": "atrib <hello@atrib.dev>",
  "license": "Apache-2.0",
  "homepage": "https://atrib.dev",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "anthropic",
    "claude",
    "agent-memory",
    "memory",
    "memory-tool",
    "verifiable",
    "atrib"
  ],
  "scripts": {
    "build": "tsc",
    "smoke": "tsx examples/filesystem-smoke.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@atrib/mcp": "workspace:*",
    "canonicalize": "^3.0.0"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.100.1"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/creatornader/atrib.git",
    "directory": "packages/memory-tool"
  }
}
