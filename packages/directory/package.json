{
  "name": "@atrib/directory",
  "version": "0.1.2",
  "description": "Identity-claim directory SDK for atrib. Publish, lookup, history, and proof-of-absence operations with cryptographic proofs per atrib spec §6.",
  "author": "atrib <hello@atrib.dev>",
  "license": "Apache-2.0",
  "homepage": "https://atrib.dev",
  "keywords": [
    "atrib",
    "akd",
    "transparency-log",
    "identity",
    "wasm"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "wasm"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc",
    "test": "vitest run"
  },
  "dependencies": {
    "@noble/ed25519": "^3.1.0",
    "@noble/hashes": "^2.2.0",
    "canonicalize": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
