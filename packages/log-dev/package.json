{
  "name": "@atrib/log-dev",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "corpus": "tsx scripts/generate-conformance-corpus.ts",
    "corpus:1.9": "tsx scripts/generate-conformance-1.9.ts",
    "corpus:6": "tsx scripts/generate-conformance-6.ts"
  },
  "dependencies": {
    "@atrib/mcp": "workspace:*",
    "@atrib/directory": "workspace:*",
    "@noble/hashes": "^2.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
