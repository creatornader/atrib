{
  "name": "@atrib/log-dev",
  "version": "0.1.24",
  "description": "In-memory dev Merkle log stub for atrib (private, dev/test fixture only).",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/creatornader/atrib",
    "directory": "packages/log-dev"
  },
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "corpus": "tsx scripts/generate-conformance-corpus.ts",
    "corpus:1.9": "tsx scripts/generate-conformance-1.9.ts",
    "corpus:6": "tsx scripts/generate-conformance-6.ts"
  },
  "dependencies": {
    "@atrib/directory": "workspace:*",
    "@atrib/mcp": "workspace:*",
    "@noble/ed25519": "^3.1.0",
    "@noble/hashes": "^2.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
