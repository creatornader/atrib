# Reduce Docker build context. Only include packages and services
# needed by the Dockerfiles (log-node needs mcp; graph-node needs mcp + verify).

.git
node_modules
dist
.env
.env.*
*.tgz
coverage
.turbo

# Workspace packages not needed by either service
packages/agent
packages/integration
packages/log-dev
packages/cli

# Non-code directories
services/log/
thoughts/
docs/

# Build artifacts
*.log
