  "rail": "acp",
  "profile_section": "2.1",
  "description": "ACP server-to-merchant order_create webhook event (snake_case event type, not dot-notation). Detected as ACP with data.permalink_url as the checkout URL.",
  "input": {
    "tool_name": "webhook_handler",
    "response": {
