        "permalink_url": "https://www.testshop.com/orders/checkout_session_123",
        "status": "created",
        "refunds": []
      }
    }
  },
  "expected": {
    "detected": true,
    "protocol": "ACP",
    "checkout_url": "https://www.testshop.com/orders/checkout_session_123"
  }
