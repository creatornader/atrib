        "ref": {
          "kind": "withheld"
        }
      },
      "result": {
        "valid": true,
        "constraints": [],
        "errors": [],
        "warnings": []
      }
    },
    "atrib_profile_registry": [
      "oauth2",
      "mcp-oauth",
      "aauth",
      "x401",
      "ap2-vi",
      "human-approval",
      "counterparty-attestation",
      "delegation-certificate",
