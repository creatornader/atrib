          "has_transaction": true,
          "cross_session_count": 0,
          "nodes": [
            { "id": "sha256:n1", "event_type": "tool_call", "content_id": "sha256:c1", "creator_key": "creator_1", "chain_root": "sha256:r1", "context_id": "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb", "timestamp": 1700000000000, "log_index": 0, "verification_state": "signature_valid", "is_genesis": true },
            { "id": "sha256:n2", "event_type": "tool_call", "content_id": "sha256:c2", "creator_key": "creator_1", "chain_root": "sha256:r2", "context_id": "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb", "timestamp": 1700000001000, "log_index": 1, "verification_state": "signature_valid", "is_genesis": false },
            { "id": "sha256:n3", "event_type": "tool_call", "content_id": "sha256:c3", "creator_key": "creator_2", "chain_root": "sha256:r3", "context_id": "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb", "timestamp": 1700000002000, "log_index": 2, "verification_state": "signature_valid", "is_genesis": false },
            { "id": "sha256:tx", "event_type": "transaction", "content_id": "sha256:tx", "creator_key": "creator_1", "chain_root": "sha256:rtx", "context_id": "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb", "timestamp": 1700000003000, "log_index": 3, "verification_state": "signature_valid", "is_genesis": false }
          ],
          "edges": [
            { "type": "CONVERGES_ON", "source": "sha256:n1", "target": "sha256:tx", "directed": true },
            { "type": "CONVERGES_ON", "source": "sha256:n2", "target": "sha256:tx", "directed": true },
            { "type": "CONVERGES_ON", "source": "sha256:n3", "target": "sha256:tx", "directed": true }
          ]
        },
        "policy": {
          "spec_version": "atrib/1.0",
          "role": "merchant",
          "edge_weights": { "CONVERGES_ON": 1.0, "unsigned": 0.0 },
