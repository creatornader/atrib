{
  "spec_version": "atrib/1.0",
  "spec_section": "§4.6 (calculation algorithm)",
  "description": "Test vectors for the attribution calculation algorithm. Any conforming implementation MUST produce identical distribution outputs for these graph+policy inputs.",
  "vectors": [
    {
      "name": "two equal contributors under default policy",
      "input": {
        "graph": {
          "spec_version": "atrib/1.0",
          "context_id": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
          "generated_at": 1700000000000,
          "node_count": 3,
          "edge_count": 2,
          "has_transaction": true,
          "cross_session_count": 0,
          "nodes": [
            { "id": "sha256:node_a", "event_type": "tool_call", "content_id": "sha256:content_a", "creator_key": "creator_alice", "chain_root": "sha256:chain_a", "context_id": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa", "timestamp": 1700000000000, "log_index": 0, "verification_state": "signature_valid", "is_genesis": true },
            { "id": "sha256:node_b", "event_type": "tool_call", "content_id": "sha256:content_b", "creator_key": "creator_bob", "chain_root": "sha256:chain_b", "context_id": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa", "timestamp": 1700000001000, "log_index": 1, "verification_state": "signature_valid", "is_genesis": false },
            { "id": "sha256:tx_node", "event_type": "transaction", "content_id": "sha256:tx_content", "creator_key": "creator_alice", "chain_root": "sha256:tx_chain", "context_id": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa", "timestamp": 1700000002000, "log_index": 2, "verification_state": "signature_valid", "is_genesis": false }
          ],
          "edges": [
            { "type": "CONVERGES_ON", "source": "sha256:node_a", "target": "sha256:tx_node", "directed": true },
            { "type": "CONVERGES_ON", "source": "sha256:node_b", "target": "sha256:tx_node", "directed": true }
          ]
        },
        "policy": {
          "spec_version": "atrib/1.0",
          "role": "default",
          "edge_weights": { "CHAIN_PRECEDES": 1.0, "SESSION_PRECEDES": 1.0, "SESSION_PARALLEL": 1.0, "CONVERGES_ON": 1.0, "CROSS_SESSION": 1.0, "unsigned": 0.0 },
          "modifiers": [],
          "distribution": "proportional",
          "constraints": {}
        }
      },
      "expected": {
        "distribution": { "creator_alice": 0.5, "creator_bob": 0.5 },
        "sum": 1.0,
        "keys_sorted": true
      }
    },
    {
      "name": "three contributors with minimum_share constraint",
      "input": {
        "graph": {
          "spec_version": "atrib/1.0",
