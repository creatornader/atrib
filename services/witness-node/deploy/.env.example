# Public witness identity. Use a DNS name controlled by the witness operator.
ATRIB_WITNESS_NAME=witness.example.org

# Canonical unpadded base64url encoding of a 32-byte Ed25519 seed.
# Generate and store this outside the source tree:
# node -e 'console.log(Buffer.from(crypto.randomBytes(32)).toString("base64url"))'
ATRIB_WITNESS_KEY=replace_with_43_character_base64url_seed

# Pin these facts through an authenticated channel independent of the live log.
ATRIB_WITNESS_LOG_URL=https://log.atrib.dev
ATRIB_WITNESS_LOG_ORIGIN=log.atrib.dev/v1
ATRIB_WITNESS_LOG_PUBLIC_KEY=replace_with_pinned_43_character_base64url_key

ATRIB_WITNESS_POLL_INTERVAL_MS=30000
PORT=3200

# Every configured source is required and checked before cosigning.
# Keep [] until an independently delivered observer source is available.
ATRIB_WITNESS_GOSSIP_SOURCES=[]
