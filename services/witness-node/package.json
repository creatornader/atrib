{
  "name": "@atrib/witness-node",
  "version": "0.1.1",
  "description": "Independent checkpoint witness service for atrib logs.",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "atrib-witness-node": "./dist/main.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "start": "node dist/main.js",
    "dev": "tsx src/main.ts",
    "prove:deployment": "node scripts/prove-deployment.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@atrib/verify": "workspace:*",
    "@noble/ed25519": "^3.1.0",
    "@noble/hashes": "^2.2.0"
  },
  "devDependencies": {
    "@atrib/mcp": "workspace:*",
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
