{
  "name": "@atrib/annotate",
  "version": "0.2.0",
  "description": "MCP server for atrib. Cognitive primitive #2 of D079: marks a past record's importance and meaning. Specialized form of @atrib/emit that narrows the schema to the annotation event_type (spec §1.2.7 / D058).",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "atrib-annotate": "./dist/main.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "start": "node dist/main.js",
    "dev": "tsx src/main.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@atrib/emit": "workspace:*",
    "@atrib/mcp": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  }
}
