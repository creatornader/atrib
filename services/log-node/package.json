{
  "name": "@atrib/log-node",
  "version": "0.1.34",
  "description": "Production Merkle log service for atrib's verifiable action layer.",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "start": "tsx src/main.ts",
    "verify-log": "node scripts/verify-loop.mjs",
    "chain-demo": "node scripts/chain-demo.mjs",
    "metrics": "node scripts/metrics.mjs",
    "log:stats": "node scripts/log-stats.mjs",
    "replay-proof-null": "node scripts/replay-proof-null-from-mirror.mjs",
    "graph-canary": "node scripts/live-graph-canary.mjs"
  },
  "dependencies": {
    "@atrib/directory": "workspace:*",
    "@atrib/mcp": "workspace:*",
    "@noble/ed25519": "^3.1.0",
    "@noble/hashes": "^2.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "canonicalize": "^3.0.0",
    "fast-check": "^4.8.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
