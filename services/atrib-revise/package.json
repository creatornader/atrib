{
  "name": "@atrib/revise",
  "version": "0.2.22",
  "description": "MCP server for atrib. Lets agents supersede a prior signed position with a stated reason. Adds a REVISES graph edge so the contradiction is a first-class node rather than a silent edit.",
  "author": "atrib <hello@atrib.dev>",
  "keywords": [
    "atrib",
    "mcp",
    "model-context-protocol",
    "attribution",
    "verifiable",
    "agent",
    "cognitive-primitive",
    "revision",
    "ed25519",
    "signed-records"
  ],
  "homepage": "https://atrib.dev",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "atrib-revise": "./dist/main.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "start": "node dist/main.js",
    "dev": "tsx src/main.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@atrib/emit": "workspace:*",
    "@atrib/mcp": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/creatornader/atrib.git",
    "directory": "services/atrib-revise"
  }
}
