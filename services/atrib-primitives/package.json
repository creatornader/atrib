{
  "name": "@atrib/primitives-runtime",
  "version": "0.2.1",
  "description": "Private local MCP runtime for atrib's verifiable action layer. Exposes all cognitive primitives from one process.",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "atrib-primitives": "./dist/index.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsc && chmod +x dist/index.js",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@atrib/attest": "workspace:*",
    "@atrib/recall": "workspace:*",
    "@atrib/summarize": "workspace:*",
    "@atrib/verify": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "files": [
    "dist"
  ]
}
