{
  "name": "@atrib/emit",
  "version": "0.17.3",
  "description": "MCP server for atrib's verifiable action layer. Lets agents sign explicit observations, annotations, and revisions.",
  "author": "atrib <hello@atrib.dev>",
  "keywords": [
    "atrib",
    "mcp",
    "model-context-protocol",
    "attribution",
    "verifiable",
    "agent",
    "cognitive-primitive",
    "ed25519",
    "signed-records",
    "observations"
  ],
  "homepage": "https://atrib.dev",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "atrib-emit": "./dist/main.js",
    "atrib-emit-cli": "./dist/cli.js",
    "atrib-local-substrate": "./dist/local-substrate-host.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsc && chmod +x dist/main.js dist/cli.js dist/local-substrate-host.js",
    "start": "node dist/main.js",
    "dev": "tsx src/main.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@atrib/mcp": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@noble/ed25519": "^3.1.0",
    "@noble/hashes": "^2.2.0",
    "canonicalize": "^3.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.22.4",
    "typescript": "^7.0.2",
    "vitest": "^4.1.8"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/creatornader/atrib.git",
    "directory": "services/atrib-emit"
  }
}
